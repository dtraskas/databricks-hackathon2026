# Lakebase endpoint resource path. Locally it resolves the host and mints OAuth
# tokens; on deploy it is injected from the binding via `valueFrom` in app.yaml.
# Find it with: databricks postgres list-endpoints projects/<project>/branches/<branch>
LAKEBASE_ENDPOINT=projects/dev-instance/branches/production/endpoints/primary

# Postgres database name (also used by the DABs binding via --var above).
PGDATABASE=databricks_postgres

# Lakebase branch (used by the DABs binding via --var above).
LAKEBASE_BRANCH=production

# Foundation model serving endpoint the agent calls. List options with:
# databricks serving-endpoints list
# (Claude endpoints like databricks-claude-opus-4-8 are disabled in this
#  workspace; switch to one once an admin raises its rate limit.)
AGENT_LLM_ENDPOINT=databricks-meta-llama-3-3-70b-instruct