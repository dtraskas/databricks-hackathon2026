from pyspark.sql.functions import col, lower, when, array, lit, concat_ws
df = spark.table("datalake_dev.facilities")

#icu contradiciton
df = df.withColumn(
    "icu_contradiction",
    when(
        (lower(col("capability")).contains("icu")) &
        (~lower(col("description")).contains("icu")),
        1
    ).otherwise(0)
)

#equipment description mismatch
df = df.withColumn(
    "equipment_contradiction",
    when(
        (col("equipment").isNotNull()) &
        (col("description").isNull() | (col("description") == "")),
        1
    ).otherwise(0)
)

#procudere exist but no capability
df = df.withColumn(
    "procedure_contradiction",
    when(
        (col("procedure").isNotNull()) &
        (col("capability").isNull()),
        1
    ).otherwise(0)
)

#high capability but missing doctors
df = df.withColumn(
    "capacity_doctor_mismatch",
    when(
        (col("capacity").isNotNull()) &
        (col("numberDoctors").isNull()),
        1
    ).otherwise(0)
)

#speciality mismatch vs capability
df = df.withColumn(
    "specialty_gap",
    when(
        (col("specialties").isNotNull()) &
        (col("capability").isNull()),
        1
    ).otherwise(0)
)

#contradiction issue tag
df = df.withColumn(
    "issue_tags",
    array(
        when(col("icu_contradiction") == 1, lit("ICU claimed without evidence")),
        when(col("equipment_contradiction") == 1, lit("Equipment not supported by description")),
        when(col("procedure_contradiction") == 1, lit("Procedure listed without capability")),
        when(col("capacity_doctor_mismatch") == 1, lit("High capacity but missing doctors")),
        when(col("specialty_gap") == 1, lit("Specialty listed but capability unclear"))
    )
)

#contradiciton severity score
df = df.withColumn(
    "contradiction_score",
    (
        col("icu_contradiction") * 30 +
        col("equipment_contradiction") * 20 +
        col("procedure_contradiction") * 20 +
        col("capacity_doctor_mismatch") * 15 +
        col("specialty_gap") * 15
    )
)

#contradiction explanation for reviewers
df = df.withColumn(
    "contradiction_explanation",
    concat_ws(
        " | ",
        when(col("icu_contradiction") == 1,
             lit("ICU capability mentioned but no supporting evidence in description")),
        when(col("equipment_contradiction") == 1,
             lit("Equipment listed without supporting facility description")),
        when(col("procedure_contradiction") == 1,
             lit("Procedure mentioned without declared capability")),
        when(col("capacity_doctor_mismatch") == 1,
             lit("Facility capacity does not align with available doctor count")),
        when(col("specialty_gap") == 1,
             lit("Specialty claims are not supported by capability data"))
    )
)

#high value review dataset
contradictions = df.select(
    "unique_id",
    "name",
    "contradiction_score",
    "issue_tags",
    "contradiction_explanation",
    "capability",
    "procedure",
    "equipment",
    "description"
)

#save for app use
contradictions.write.mode("overwrite").option("overwriteSchema", "true").saveAsTable(
    "workspace.l1_facility_info.contradiction_signals"
)
